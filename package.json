{
	"name": "splitzone",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "expo start",
		"reset-project": "node ./scripts/reset-project.js",
		"android": "expo start --android",
		"ios": "expo start --ios",
		"web": "expo start --web",
		"lint": "expo lint",
		"lint:biome": "npx @biomejs/biome check",
		"format": "npx @biomejs/biome format --write",
		"test": "echo \"No tests specified\" && exit 0",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css}": [
			"npx @biomejs/biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@auth/core": "^0.37.0",
		"@convex-dev/auth": "^0.0.90",
		"@hookform/resolvers": "^5.2.2",
		"@react-navigation/bottom-tabs": "^7.12.0",
		"@react-navigation/drawer": "^7.8.0",
		"@react-navigation/elements": "^2.9.5",
		"@react-navigation/native": "^7.1.28",
		"convex": "^1.31.7",
		"expo": "~54.0.33",
		"expo-clipboard": "~8.0.8",
		"expo-constants": "~18.0.13",
		"expo-font": "~14.0.11",
		"expo-linking": "~8.0.11",
		"expo-router": "~6.0.23",
		"expo-secure-store": "~15.0.8",
		"expo-splash-screen": "~31.0.13",
		"expo-status-bar": "~3.0.9",
		"expo-system-ui": "~6.0.9",
		"lucide-react-native": "^0.563.0",
		"nativewind": "^4.2.1",
		"prettier-plugin-tailwindcss": "^0.5.14",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hook-form": "^7.71.1",
		"react-native": "0.83.1",
		"react-native-gesture-handler": "~2.30.0",
		"react-native-reanimated": "~4.2.1",
		"react-native-safe-area-context": "^5.6.2",
		"react-native-screens": "~4.22.0",
		"react-native-svg": "^15.15.1",
		"react-native-web": "~0.21.2",
		"react-native-worklets": "0.7.2",
		"tailwindcss": "^3.4.19",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@types/react": "~19.2.10",
		"eslint": "^9.39.2",
		"eslint-config-expo": "~10.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"typescript": "~5.9.3"
	},
	"private": true
}
